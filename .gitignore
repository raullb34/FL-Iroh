# =============================================================================
# FL-Iroh — .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Datasets (large binary data — download via setup_env.sh) ─────────────────
data/
# Keep the directory so git tracks the placeholder
!data/.gitkeep
# Un-ignore parent dirs so git traverses into them for the exceptions below
!data/air-quailty/
!data/air-quailty/datasets/
!data/air-quailty/notebooks/
# Keep the processed ML-ready datasets (small CSVs generated by preprocess_e7.py)
!data/air-quailty/datasets/air_quality_fl_classification.csv
!data/air-quailty/datasets/air_quality_fl_timeseries.csv
!data/air-quailty/datasets/air_quality_ica_thresholds.json
# Keep the preprocessing script
!data/air-quailty/notebooks/preprocess_e7.py

# ── Experiment results ────────────────────────────────────────────────────────
# Per-run outputs backing the paper's tables ARE tracked (data availability).
# Local scratch ("* copy" dirs, ad-hoc dev runs, transient reports) is not.
results/* copy/
results/B_*
results/report_*.json
results/server_endpoint.json

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore
docker/.buildx-cache/

# ── Large archives ────────────────────────────────────────────────────────────
*.tar.gz
*.tar.bz2
*.zip
*.tgz

# ── Logs and temp files ───────────────────────────────────────────────────────
*.log
*.out
*.err
# Experiment-run logs under results/ are evidentiary — keep them tracked
!results/**/*.log
*.tmp
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Coverage / testing ───────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── SLURM runtime artifacts ───────────────────────────────────────────────────
slurm*.out
slurm*.err

# -- LaTeX build artifacts (keep .tex, .bib, .cls, .sty, .bst and .pdf) -------
*.aux
*.abs
*.bbl
*.blg
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.spl
*.brf
*.nav
*.snm
*.vrb
